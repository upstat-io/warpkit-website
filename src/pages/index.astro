---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.svelte';
import Starfield from '../components/Starfield.svelte';
import FeatureCard from '../components/FeatureCard.svelte';
import HeroCode from '../components/HeroCode.svelte';
import Footer from '../components/Footer.svelte';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="WarpKit — Svelte 5 SPA Framework">
  <Starfield client:load />
  <Nav client:load />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-badge">Alpha Release</div>
        <h1>Navigate your app<br/>at <span class="hero-warp">warp speed</span></h1>
        <p class="hero-sub">
          A Svelte 5 framework for SPAs. State-based routing, data fetching,
          schema-driven forms, and real-time capabilities — all in one stack.
        </p>
        <div class="hero-actions">
          <a href={`${base}/docs`} class="btn btn-primary">Get Started</a>
          <a href="https://github.com/upstat-io/warpkit" class="btn btn-glass" target="_blank" rel="noopener noreferrer">
            View on GitHub
          </a>
        </div>
        <!-- LCARS-subtle decorative bar -->
        <div class="lcars-bar hero-bar">
          <span class="seg-amber" style="flex: 4"></span>
          <span class="seg-mauve" style="flex: 1.5"></span>
          <span class="seg-cyan" style="flex: 2.5"></span>
          <span class="seg-coral" style="flex: 0.8"></span>
          <span class="seg-amber" style="flex: 1"></span>
        </div>
      </div>
    </section>

    <!-- CODE EXAMPLE -->
    <section class="code-section">
      <div class="container">
        <div class="code-layout">
          <div class="code-intro">
            <h2>Ship fast,<br/>stay organized</h2>
            <p>
              Routes organized by application state. Every navigation flows through
              a predictable pipeline. Auth, data, and forms just work.
            </p>
          </div>
          <HeroCode client:load />
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Core capabilities</span>
          <h2>Everything you need to build</h2>
        </div>
        <div class="feature-grid">
          <FeatureCard
            client:visible
            title="State-Based Routing"
            description="Routes organized by application state — authenticated, onboarding, admin. The router knows where users belong."
            accent="amber"
          />
          <FeatureCard
            client:visible
            title="Navigation Pipeline"
            description="Every navigation flows through 10 predictable phases. Guards, middleware, data loading — in a defined order."
            accent="mauve"
          />
          <FeatureCard
            client:visible
            title="Auth Agnostic"
            description="Bring your own auth. Firebase, Auth0, or custom — WarpKit provides the adapter pattern, you provide the provider."
            accent="cyan"
          />
          <FeatureCard
            client:visible
            title="Data Layer"
            description="Config-driven data fetching with E-Tag caching, stale-while-revalidate, and automatic refetching built in."
            accent="coral"
          />
          <FeatureCard
            client:visible
            title="Schema-Driven Forms"
            description="Deep proxy binding with StandardSchema validation. Zod, TypeBox — pick your validator, WarpKit handles the rest."
            accent="amber"
          />
          <FeatureCard
            client:visible
            title="Real-Time WebSockets"
            description="Type-safe messages, rooms, and automatic reconnection. First-class real-time without the boilerplate."
            accent="mauve"
          />
        </div>
      </div>
    </section>

    <!-- PACKAGES -->
    <section class="packages">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Modular by design</span>
          <h2>Pick what you need</h2>
        </div>
        <div class="pkg-list">
          <div class="pkg glass">
            <code class="pkg-name">@warpkit/core</code>
            <span class="pkg-desc">Router, state machine, components</span>
          </div>
          <div class="pkg glass">
            <code class="pkg-name">@warpkit/data</code>
            <span class="pkg-desc">Data fetching, caching, mutations</span>
          </div>
          <div class="pkg glass">
            <code class="pkg-name">@warpkit/cache</code>
            <span class="pkg-desc">Memory, Storage, E-Tag caches</span>
          </div>
          <div class="pkg glass">
            <code class="pkg-name">@warpkit/forms</code>
            <span class="pkg-desc">Schema-driven form management</span>
          </div>
          <div class="pkg glass">
            <code class="pkg-name">@warpkit/validation</code>
            <span class="pkg-desc">StandardSchema validation</span>
          </div>
          <div class="pkg glass">
            <code class="pkg-name">@warpkit/websocket</code>
            <span class="pkg-desc">WebSocket client with reconnection</span>
          </div>
        </div>
      </div>
    </section>

    <!-- INSTALL -->
    <section class="install-section">
      <div class="container">
        <div class="install-card glass">
          <h2>Start building</h2>
          <div class="install-cmd">
            <code>bun add @warpkit/core @warpkit/data @warpkit/cache</code>
          </div>
          <div class="install-actions">
            <a href={`${base}/docs`} class="btn btn-primary">Read the docs</a>
            <a href={`${base}/guide`} class="btn btn-glass">Follow the guide</a>
          </div>
          <div class="lcars-bar" style="margin-top: 32px">
            <span class="seg-cyan" style="flex: 2"></span>
            <span class="seg-amber" style="flex: 4"></span>
            <span class="seg-mauve" style="flex: 1"></span>
          </div>
        </div>
      </div>
    </section>
    <!-- OTHER PROJECTS -->
    <section class="projects">
      <div class="container">
        <div class="section-header">
          <span class="section-label">From the team</span>
          <h2>Other projects</h2>
        </div>
        <div class="projects-grid">
          <a href="https://upstat.io" target="_blank" rel="noopener" class="project-card glass">
            <div class="project-icon">
              <svg viewBox="0 0 33 33" fill="none">
                <path d="M5.39 23.44L3.22 21.27l-.37.37.33.4a29.5 29.5 0 0 1 7.86-4.53c2.15-.74 4.21-1.04 6.02-.87l.05-.52-.52.05c.16 1.81-.14 3.88-.88 6.03a29.5 29.5 0 0 1-4.52 7.86l.4.33.37-.37-2.17-2.17a.52.52 0 0 1 .74-.74l2.17 2.17c.1.1.25.16.39.15a.52.52 0 0 0 .38-.19 31 31 0 0 0 4.71-8.18c.78-2.26 1.1-4.47.93-6.46a.52.52 0 0 0-.47-.47c-2-.18-4.2.13-6.46.9A31 31 0 0 0 2.52 21.24a.52.52 0 0 0 .15.77l2.17 2.17a.52.52 0 0 0 .74-.74Z" fill="var(--amber)" stroke="var(--amber)" stroke-width="0.3"/>
                <path d="M27.72 15.25a.5.5 0 0 1-.14.08.52.52 0 0 1-.64-.09l-2.26-1.98-5 2.19a.52.52 0 0 1-.63-.15.52.52 0 0 1-.11-.55l2.73-5.13-2.83 1.21a.4.4 0 0 1-.43-.04.4.4 0 0 1-.22-.46l.33-2.04-1.27-1.12a.4.4 0 0 1-.04-.53.4.4 0 0 1 .08-.11.5.5 0 0 1 .13-.09.52.52 0 0 1 .65.08l1.47 1.29a.4.4 0 0 1 .16.41l-.22 1.38 3.3-1.41a.52.52 0 0 1 .49.09.52.52 0 0 1 .11.55l-2.72 5.11 3.94-1.73a.52.52 0 0 1 .61.07l.03.02 2.54 2.23a.4.4 0 0 1 .08.86.5.5 0 0 1-.12.16Z" fill="var(--cyan)" stroke="var(--cyan)" stroke-width="0.15"/>
                <path d="M9.55 23.29L5.18 27.65a.52.52 0 0 0 .74.74l4.37-4.37a.52.52 0 0 0-.74-.74Z" fill="var(--amber)" stroke="var(--amber)" stroke-width="0.3"/>
                <path d="M6.4 23.21L1.2 28.41a.52.52 0 0 0 .74.74l5.2-5.2a.52.52 0 0 0-.74-.74Z" fill="var(--amber)" stroke="var(--amber)" stroke-width="0.3"/>
                <path d="M10.38 26.3L5.18 31.5a.52.52 0 0 0 .74.74l5.2-5.2a.52.52 0 0 0-.74-.74Z" fill="var(--amber)" stroke="var(--amber)" stroke-width="0.3"/>
                <path d="M3.68 29.17L1.2 31.65a.52.52 0 0 0 .74.74l2.48-2.48a.52.52 0 0 0-.74-.74Z" fill="var(--amber)" stroke="var(--amber)" stroke-width="0.3"/>
                <path d="M16.11 23.41c3.5-.76 7-2.63 9.91-5.54 3.89-3.9 5.93-8.83 5.93-13.42 0-.82-.07-1.63-.2-2.42l-.05-.32-.32-.05A14.5 14.5 0 0 0 28.95 1.46c-4.59 0-9.52 2.03-13.41 5.92-2.92 2.92-4.79 6.42-5.54 9.92l.89.19c.72-3.32 2.5-6.67 5.3-9.46 3.73-3.73 8.45-5.66 12.77-5.66.77 0 1.53.06 2.27.19l.08-.45-.45.08c.12.74.19 1.5.19 2.27 0 4.32-1.93 9.04-5.66 12.77-2.8 2.8-6.14 4.58-9.46 5.3l.19.89Z" fill="var(--amber)" stroke="var(--amber)" stroke-width="0.3"/>
              </svg>
            </div>
            <h3>Upstat</h3>
            <p>Incident response &amp; operational intelligence for DevOps and SREs.</p>
            <span class="project-url">upstat.io</span>
          </a>
          <a href="https://orijs.dev" target="_blank" rel="noopener" class="project-card glass">
            <div class="project-icon">
              <svg viewBox="0 0 28 28" fill="none">
                <circle cx="14" cy="14" r="12" stroke="var(--amber)" stroke-width="2" fill="none"/>
                <path d="M14 6C10 10 8 16 14 22C20 16 18 10 14 6Z" fill="var(--cyan)" opacity="0.7"/>
                <path d="M14 8C12 12 10 16 14 20" stroke="var(--cyan)" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
            <h3>OriJs</h3>
            <p>NestJS-inspired backend framework for Bun. Provider-based DI, no decorators.</p>
            <span class="project-url">orijs.dev</span>
          </a>
          <a href="https://ori-lang.com" target="_blank" rel="noopener" class="project-card glass">
            <div class="project-icon">
              <svg viewBox="0 0 32 32" fill="none">
                <path d="M9 9 L17 16 L9 23" stroke="var(--amber)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M17 9 L25 16 L17 23" stroke="var(--cyan)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Ori Lang</h3>
            <p>Expression-based language with automatic reference counting. No GC, no borrow checker.</p>
            <span class="project-url">ori-lang.com</span>
          </a>
          <a href="https://oriterm.com" target="_blank" rel="noopener" class="project-card glass">
            <div class="project-icon">
              <svg viewBox="80 150 320 300" fill="none">
                <polyline points="120,188 228,296 120,404" fill="none" stroke="var(--amber)" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="280" y="388" width="110" height="18" rx="5" fill="var(--cyan)" opacity="0.8"/>
              </svg>
            </div>
            <h3>Ori Term</h3>
            <p>GPU-accelerated terminal OS. Emulation, multiplexing, and sessions unified.</p>
            <span class="project-url">oriterm.com</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Base>

<style>
  main {
    padding-top: 60px;
  }

  /* --- HERO --- */
  .hero {
    padding: 100px 0 80px;
    text-align: center;
    position: relative;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--amber);
    background: var(--amber-glow);
    border: var(--border-weight) solid rgba(245, 166, 35, 0.2);
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    margin-bottom: 28px;
    letter-spacing: 0.02em;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--text-bright);
    max-width: 700px;
  }

  .hero-warp {
    background: linear-gradient(135deg, var(--amber), var(--mauve));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    margin-top: 24px;
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 540px;
    text-align: center;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 36px;
  }

  .hero-bar {
    margin-top: 64px;
    width: 100%;
    max-width: 500px;
  }

  /* --- BUTTONS --- */
  .btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 10px 24px;
    border-radius: var(--radius-pill);
    transition: transform 0.15s, background 0.2s;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--amber);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: #fdb644;
    color: var(--bg);
  }

  .btn-glass {
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: var(--border-weight) solid var(--glass-border);
    color: var(--text);
  }

  .btn-glass:hover {
    border-color: var(--glass-border-hover);
    color: var(--text-bright);
  }

  /* --- CODE SECTION --- */
  .code-section {
    padding: 80px 0;
  }

  .code-layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 60px;
    align-items: center;
  }

  .code-intro h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .code-intro p {
    margin-top: 16px;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  /* --- FEATURES --- */
  .features {
    padding: 80px 0;
  }

  .section-header {
    margin-bottom: 48px;
  }

  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--amber);
    margin-bottom: 8px;
    letter-spacing: 0.04em;
  }

  .section-header h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    letter-spacing: -0.015em;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* --- PACKAGES --- */
  .packages {
    padding: 80px 0;
  }

  .pkg-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .pkg {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: border-color 0.2s;
  }

  .pkg:hover {
    border-color: var(--glass-border-hover);
  }

  .pkg-name {
    font-size: 0.85rem;
    color: var(--amber);
    background: none;
    border: none;
    padding: 0;
  }

  .pkg-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* --- INSTALL --- */
  .install-section {
    padding: 60px 0;
  }

  .install-card {
    padding: 48px;
    text-align: center;
  }

  .install-card h2 {
    font-size: 1.8rem;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .install-cmd {
    display: inline-block;
    background: rgba(0, 0, 0, 0.4);
    border: var(--border-weight) solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 14px 28px;
    margin-bottom: 28px;
  }

  .install-cmd code {
    font-size: 0.88rem;
    color: var(--text);
    background: none;
    border: none;
    padding: 0;
  }

  .install-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  /* --- PROJECTS --- */
  .projects {
    padding: 80px 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.15s;
  }

  .project-card:hover {
    border-color: var(--glass-border-hover);
    transform: translateY(-1px);
  }

  .project-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-glow);
    border: 1px solid rgba(245, 166, 35, 0.2);
    border-radius: var(--radius-sm);
    margin-bottom: 16px;
  }

  .project-icon svg {
    width: 26px;
    height: 26px;
  }

  .project-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 6px;
  }

  .project-card p {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-url {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--amber);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .project-card:hover .project-url {
    opacity: 1;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 768px) {
    .code-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .pkg-list {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .install-card {
      padding: 32px 20px;
    }

    .install-actions {
      flex-direction: column;
      align-items: center;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .pkg-list {
      grid-template-columns: repeat(2, 1fr);
    }

    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
