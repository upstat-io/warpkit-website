---
import { getCollection } from 'astro:content';

interface Props {
  section: 'guide' | 'docs';
  currentPath: string;
}

const { section, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const guideEntries = (await getCollection('guide'))
  .sort((a, b) => a.data.order - b.data.order);

const docsEntries = (await getCollection('docs'))
  .filter(e => !e.id.startsWith('_'))
  .sort((a, b) => a.data.order - b.data.order);

function isActive(href: string) {
  return currentPath.replace(/\/$/, '') === href.replace(/\/$/, '');
}

// Lucide icon SVG paths (24x24 viewBox, stroke-based)
const guideIcons: Record<string, string> = {
  '01-introduction': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  '02-quick-start': '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  '03-state-based-routing': '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  '04-navigation-pipeline': '<polygon points="3 11 22 2 13 21 11 13 3 11"/>',
  '05-provider-system': '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h3v3H7z"/><path d="M14 7h3v3h-3z"/><path d="M7 14h3v3H7z"/><path d="M14 14h3v3h-3z"/>',
  '06-data-fetching': '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>',
  '07-forms': '<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
  '08-websockets': '<path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" x2="12.01" y1="20" y2="20"/>',
  '09-authentication': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  '10-testing': '<path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16.5h10"/>',
  '11-architecture': '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
};

const docsIcons: Record<string, string> = {
  'packages': '<path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" x2="12" y1="22" y2="12"/>',
  'components': '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>',
  'core-internals': '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
  'providers': '<path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/><path d="M12 17v5"/>',
  'events-errors': '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
  'testing': '<path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16.5h10"/>',
};
---

<aside class="sidebar">
  <nav class="sidebar-nav" aria-label="Documentation navigation">
    <div class="sidebar-section">
      <h3 class="sidebar-heading">Guide</h3>
      <ul class="sidebar-list">
        {guideEntries.map(entry => {
          const href = `${base}/guide/${entry.id}`;
          const icon = guideIcons[entry.id];
          return (
            <li>
              <a href={href} class:list={['sidebar-link', { active: isActive(href) }]}>
                {icon && (
                  <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={icon} />
                  </svg>
                )}
                {entry.data.title}
              </a>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- Separator bar -->
    <div class="sidebar-divider">
      <span class="div-seg seg-amber"></span>
      <span class="div-seg seg-mauve"></span>
    </div>

    <div class="sidebar-section">
      <h3 class="sidebar-heading">API Reference</h3>
      <ul class="sidebar-list">
        {docsEntries.map(entry => {
          const href = `${base}/docs/${entry.id}`;
          const icon = docsIcons[entry.id];
          return (
            <li>
              <a href={href} class:list={['sidebar-link', { active: isActive(href) }]}>
                {icon && (
                  <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={icon} />
                  </svg>
                )}
                {entry.data.title}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</aside>

<style>
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    padding: 28px 16px 40px 20px;
    border-right: 1px solid var(--glass-border);
    background: rgba(6, 10, 20, 0.5);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: sticky;
    top: 60px;
    height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .sidebar-section {
    margin-bottom: 8px;
  }

  .sidebar-heading {
    padding-left: 10px;
    margin-bottom: 8px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* LCARS divider between sections */
  .sidebar-divider {
    display: flex;
    gap: 3px;
    height: 3px;
    margin: 16px 10px;
  }

  .div-seg {
    border-radius: var(--radius-pill);
  }

  .div-seg:first-child { flex: 2; }
  .div-seg:last-child { flex: 1; }

  .seg-amber { background: var(--amber); opacity: 0.4; }
  .seg-mauve { background: var(--mauve); opacity: 0.4; }

  /* Links */
  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s;
    line-height: 1.4;
  }

  .sidebar-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .sidebar-link:hover {
    color: var(--text-bright);
    background: rgba(255, 255, 255, 0.04);
  }

  .sidebar-link:hover .sidebar-icon {
    opacity: 0.9;
  }

  .sidebar-link.active {
    color: var(--amber);
    background: var(--amber-glow);
  }

  .sidebar-link.active .sidebar-icon {
    opacity: 1;
  }

  /* Scrollbar */
  .sidebar::-webkit-scrollbar {
    width: 4px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--glass-border);
      padding: 16px;
    }

    .sidebar-nav {
      display: flex;
      gap: 32px;
    }

    .sidebar-section {
      margin-bottom: 0;
    }

    .sidebar-divider {
      display: none;
    }

    .sidebar-list {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .sidebar-icon {
      display: none;
    }
  }
</style>
